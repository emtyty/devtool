{
  "name": "exifmaster-pro",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "mcp:install": "cd mcp && npm install",
    "mcp:build": "cd mcp && npm run build",
    "mcp:dev": "cd mcp && npm run dev",
    "mcp:inspect": "cd mcp && npx @modelcontextprotocol/inspector node dist/index.js",
    "docs:dev": "cd docs && npm run dev",
    "docs:build": "cd docs && npm run build",
    "docs:preview": "cd docs && npm run preview",
    "og:generate": "node scripts/gen-og-png.mjs",
    "icons:generate": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@6over3/zeroperl-ts": "^1.0.10",
    "@faker-js/faker": "^10.3.0",
    "@google/genai": "^1.43.0",
    "@types/papaparse": "^5.5.2",
    "@uswriting/exiftool": "^1.0.9",
    "ag-psd": "^20.2.3",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "heic2any": "^0.0.4",
    "html-query-plan": "^2.6.1",
    "html2canvas": "^1.4.1",
    "jsonrepair": "^3.13.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.576.0",
    "mammoth": "^1.12.0",
    "marked": "^17.0.6",
    "mermaid": "^11.13.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql-formatter": "^15.7.2",
    "stacktrace-parser": "^0.1.11",
    "utif": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.44.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^25.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.2.0",
    "vitest": "^2.0.0"
  }
}
